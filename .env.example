# URL publica do site (usada em metadata, sitemap, robots)
NEXT_PUBLIC_SITE_URL=https://shopping-fortaleza.example

# Endpoint Formspree do formulario de contacto. Sem isto, o form mostra
# sucesso na mesma (fallback gracioso) mas nao envia.
NEXT_PUBLIC_FORMSPREE_ENDPOINT=https://formspree.io/f/your-form-id

# String de embed do Google Maps (o valor "pb=..." do iframe partilhado)
NEXT_PUBLIC_GOOGLE_MAPS_EMBED=https://www.google.com/maps/embed?pb=YOUR_EMBED_STRING

# Numero de WhatsApp em formato internacional sem "+" (ex: 244923000000)
NEXT_PUBLIC_WHATSAPP=244923000000
